# LLM providers (at least one required for search)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Semantic Scholar (optional — backup source, not primary)
SEMANTIC_SCHOLAR_KEY=

# Cloudflare R2 (only needed for `gradradar db publish` — end users do NOT need these)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=gradradar-db
# Public read URL — has a default in config.py so end users can skip this entirely
CLOUDFLARE_R2_PUBLIC_URL=

# Overrides (optional)
GRADRADAR_DB_PATH=              # default: ~/.gradradar/db/
GRADRADAR_LLM_MODEL=           # default: claude-sonnet-4-5-20241022
GRADRADAR_WEB_SEARCH=           # default: true
